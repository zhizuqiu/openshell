{
  "name": "@zhizuqiu/openshell",
  "version": "1.0.12",
  "description": "OpenShell CLI - Natural Language Command-Line Assistant",
  "license": "MIT",
  "type": "module",
  "bin": {
    "openshell": "dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "preferGlobal": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node dist/index.js",
    "build": "tsc",
    "dev": "npm run build && npm run start",
    "clean": "rm -rf dist *.tsbuildinfo",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "files": [
    "dist",
    "package.json",
    "README.md"
  ],
  "devDependencies": {
    "@types/node": "^20.11.24",
    "@types/react": "^19.2.0",
    "@types/yargs": "^17.0.32",
    "eslint": "^9.24.0",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.0.0",
    "ink-testing-library": "^4.0.0",
    "prettier": "^3.5.3",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.30.1",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@langchain/core": "^1.1.15",
    "@langchain/langgraph": "1.1.1",
    "@langchain/openai": "^1.2.13",
    "dotenv": "^17.1.0",
    "ink": "^6.6.0",
    "ink-big-text": "^2.0.0",
    "ink-gradient": "^3.0.0",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "langchain": "^1.2.10",
    "react": "^19.2.0",
    "yargs": "^17.7.2",
    "zod": "4.3.5"
  }
}
